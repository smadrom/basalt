{
  "name": "@basalt/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "auth:migrate": "bunx @better-auth/cli migrate"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/openapi": "^1.2.0",
    "better-auth": "^1.6.14",
    "drizzle-orm": "^0.38.0",
    "elysia": "^1.2.0",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
