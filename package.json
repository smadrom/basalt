{
  "name": "basalt",
  "private": true,
  "packageManager": "bun@1.3.14",
  "description": "A full-stack TypeScript starter built with Bun, Elysia, PostgreSQL, and React.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=@basalt/api",
    "dev:web": "turbo run dev --filter=@basalt/web",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:integration": "bun run --filter @basalt/api test:integration",
    "typecheck": "turbo run typecheck",
    "check": "turbo run typecheck test",
    "verify": "bun run audit && bun run lint && turbo run typecheck test build",
    "audit": "bun audit --audit-level=high",
    "lint": "biome ci .",
    "format": "biome check --write .",
    "db:up": "docker compose -f docker/docker-compose.yml up -d",
    "db:down": "docker compose -f docker/docker-compose.yml down",
    "db:generate": "turbo run db:generate --filter=@basalt/api",
    "db:migrate": "turbo run db:migrate --filter=@basalt/api"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "turbo": "^2.10.5",
    "typescript": "^7.0.2"
  }
}
